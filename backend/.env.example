# Copy this file to .env and fill in values for local development.
# All variables have sensible defaults — only override what differs.

# API server
PORT=4000
# Change to production in production environments
NODE_ENV=development

# PostgreSQL — POSTGRES_PASSWORD is the single password variable.
# Used by both the api (pg pool) and the postgres container init (via env_file).
PGHOST=localhost
PGPORT=5432
PGDATABASE=shopdeck
PGUSER=shopdeck
POSTGRES_PASSWORD=shopdeck_dev

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# CORS — comma-separated browser origins allowed to call the API directly.
# Leave empty when the API is only reached via the Next.js proxy (recommended).
CORS_ORIGIN=

# Auth — change this to a strong random string before deploying
JWT_SECRET=shopdeck-dev-secret-change-in-prod

# Email verification
# APP_BASE_URL should point to the frontend app origin (used in verification links)
# Optional: GitHub OAuth (leave commented out to disable)
#GITHUB_OAUTH_CLIENT_ID=YOUR_GITHUB_OAUTH_CLIENT_ID
#GITHUB_OAUTH_CLIENT_SECRET=YOUR_GITHUB_OAUTH_CLIENT_SECRET

# Optional: Google OAuth — ID-token sign-in + account linking
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorised JavaScript origins must include the value of FRONTEND_URL below.
#GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID

# Frontend URL — used to build email verification links
# Set to your public domain in production (e.g. https://shopdeck.app)
FRONTEND_URL=http://localhost:3000

# Email / SendGrid — leave blank to fall back to console.log in development
# Sign up at https://sendgrid.com/ and verify a From address below.
#SENDGRID_API_KEY=SG.YOUR_SENDGRID_API_KEY
#EMAIL_FROM=noreply@yourdomain.com

# Email verification enforcement
# When set to "true" users must verify before logging in.
# Defaults to false (soft block with amber banner only).
REQUIRE_EMAIL_VERIFICATION=false

# Dev-mode email sandbox — immediately marks users as email_verified=true on
# registration so you never need to click a verification link locally.
# Also enables GET /api/auth/dev/verify-url for manual flow testing.
# Only honoured when NODE_ENV=development. Silently ignored in production.
DEV_AUTO_VERIFY_EMAIL=true

# Token encryption — required for GitHub OAuth token storage.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters. Different values on different envs = tokens invalidated.
TOKEN_ENCRYPTION_KEY=GENERATE_A_64_CHAR_HEX_STRING_AND_PUT_IT_HERE

# ─── Optional vendor API keys ──────────────────────────────────────────────────
# These are stored per-user in the DB (encrypted). The variables below are only
# needed if you want to hard-code fallback keys for local testing.

# Amazon Product Advertising API v5
# https://affiliate-program.amazon.com/assoc_credentials/home
#AMAZON_ACCESS_KEY=YOUR_AMAZON_ACCESS_KEY
#AMAZON_SECRET_KEY=YOUR_AMAZON_SECRET_KEY
#AMAZON_PARTNER_TAG=YOUR_AMAZON_ASSOCIATE_TAG
#AMAZON_REGION=us-east-1

# Digikey Product Search API v4 — OAuth2 client credentials
# https://developer.digikey.com/
#DIGIKEY_CLIENT_ID=YOUR_DIGIKEY_CLIENT_ID
#DIGIKEY_CLIENT_SECRET=YOUR_DIGIKEY_CLIENT_SECRET

# Mouser Search API v2 — simple API key
# https://www.mouser.com/api-search/
# NOTE: Mouser ToS §4 prohibits caching. Responses are never cached.
#MOUSER_API_KEY=YOUR_MOUSER_API_KEY

# CJ Affiliate API — personal access token
# Powers Home Depot, Lowe's, DICK'S Sporting Goods, Zappos, Dick Blick, JOANN,
# Burpee Seeds, RockAuto, Academy Sports, and other CJ merchant product feeds.
# https://developers.cj.com/
#CJ_API_KEY=YOUR_CJ_PERSONAL_ACCESS_TOKEN

# Kroger Product API — OAuth2 client credentials
# Powers Grocery feed widgets (weekly deals, produce, pantry staples, meat).
# Register a public application at https://developer.kroger.com/
#KROGER_CLIENT_ID=YOUR_KROGER_CLIENT_ID
#KROGER_CLIENT_SECRET=YOUR_KROGER_CLIENT_SECRET

# IsThereAnyDeal API — simple API key
# Powers the Games / Video Game Deals widget. A free tier works without a key.
# Register at https://isthereanydeal.com/dev/app/
#ITAD_API_KEY=YOUR_ITAD_API_KEY

# Walmart Affiliate API (Impact Radius) — per-user fallback
# Users can also set their own key in Settings → API Keys.
# https://advertising.walmart.com/
#WALMART_IMPACT_API_KEY=YOUR_WALMART_IMPACT_API_KEY

# Ollama (AI assistant — local inference)
# Only used when a user selects the Ollama provider in AI Assistant settings.
# Defaults to http://localhost:11434 if unset.
#OLLAMA_BASE_URL=http://localhost:11434

# ─────────────────────────────────────────────────────────────────────────────
# Plaid (optional — bank account linking)
# When all three are set, users may link bank accounts during onboarding and
# from Settings → Accounts. The features endpoint returns { plaid: true }.
# Set PLAID_ENV=sandbox for testing, development, or production for live.
# In NODE_ENV=development, PLAID_ENV defaults to sandbox automatically.
# https://dashboard.plaid.com/
#PLAID_CLIENT_ID=
#PLAID_SECRET=
#PLAID_ENV=sandbox