{
  "name": "shopdeck",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "playwright test --config=playwright.config.ts",
    "test:feed": "vitest run --config backend/vitest.config.ts",
    "test:regression": "npm run lint && npm run typecheck && npm run test && npm run test:feed",
    "start": "next start",
    "backend": "npm start --prefix backend",
    "docker:ui": "docker build -f Dockerfile.frontend -t shopdeck-frontend .",
    "docker": "docker compose up --build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@react-oauth/google": "^0.13.4",
    "next": "^16.1.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-plaid-link": "^4.1.1",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^27.2.0",
    "postcss": "^8.5.8",
    "typescript": "~5.9.3",
    "vitest": "^3.2.4"
  }
}
