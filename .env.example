# Postgres credentials — must match the values in backend/.env
# docker-compose.yml reads these via ${POSTGRES_PASSWORD} etc.
POSTGRES_DB=shopdeck
POSTGRES_USER=shopdeck
POSTGRES_PASSWORD=secure-db-password
API_URL=http://api:4000

# Google OAuth — must match GOOGLE_CLIENT_ID in backend/.env
# The browser-side <GoogleOAuthProvider> uses this value.
# Leave blank if Google OAuth is not configured.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=